{
  "communicators": {
    "glm": {
      "provider": "openai-completion",
      "model": "GLM5.2",
      "apiKey": "${ZAI_API_KEY}",
      "baseURL": "https://api.z.ai/api/paas/v4",
      "capabilities": ["chat"],
      "input": ["text"],
      "output": ["text"],
      "contextLength": 128000
    }
  },
  "default": "glm"
}
