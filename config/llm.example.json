{
  "communicators": {
    "my-llm": {
      "provider": "openai-completion",
      "model": "gpt-4o-mini",
      "apiKey": "${OPENAI_API_KEY}",
      "baseURL": "https://api.openai.com/v1",
      "capabilities": ["chat"],
      "input": ["text", "image"],
      "output": ["text"],
      "contextLength": 128000
    }
  },
  "default": "my-llm"
}
