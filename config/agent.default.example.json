{
  "intervalMs": 900000,
  "plugins": [
    "llm-core",
    "persona",
    "system-prompt",
    "krakeycode",
    "searxng",
    "inspector"
  ],
  "privatePlugins": [
    "web-chat",
    "browser"
  ],
  "config": {
    "persona": {
      "text": "You are Krakey, an autonomous agent. Be concise and helpful."
    },
    "llm-core": {},
    "web-chat": {
      "port": 7718
    },
    "krakeycode": {},
    "searxng": {
      "instanceUrl": null,
      "localUrl": "http://localhost:8080",
      "usePublicFallback": true
    },
    "inspector": {},
    "browser": {
      "headless": false,
      "chromePath": null
    }
  }
}
