{
  "intervalMs": 30000,
  "plugins": [
    "llm-core",
    "persona",
    "system-prompt",
    "web",
    "krakeycode",
    "searxng",
    "browser",
    "memory-note",
    "history"
  ],
  "privatePlugins": [
    "web",
    "memory-note",
    "history"
  ],
  "config": {
    "persona": {
      "text": "You are Krakey, an autonomous agent. Be concise and helpful."
    },
    "llm-core": {},
    "web": {
      "port": 7717
    },
    "krakeycode": {},
    "searxng": {
      "instanceUrl": null,
      "localUrl": "http://localhost:8080",
      "usePublicFallback": true
    },
    "browser": {
      "headless": true,
      "chromePath": null
    },
    "memory-note": {},
    "history": {}
  }
}
