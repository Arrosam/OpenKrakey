{
  "name": "openkrakey",
  "version": "0.0.0",
  "description": "Minimalist microkernel autonomous-agent framework — time-driven, non-blocking, plugin-everything.",
  "type": "module",
  "license": "MIT",
  "author": "Samuel",
  "homepage": "https://github.com/Arrosam/OpenKrakey#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arrosam/OpenKrakey.git"
  },
  "bugs": {
    "url": "https://github.com/Arrosam/OpenKrakey/issues"
  },
  "keywords": [
    "agent",
    "autonomous-agent",
    "ai-agent",
    "llm",
    "microkernel",
    "plugin",
    "event-driven",
    "non-blocking",
    "typescript",
    "self-hosted"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "krakey": "packages/cli/src/bin.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "start": "tsx packages/boot/src/index.ts",
    "cli": "tsx packages/cli/src/bin.ts",
    "config:web": "tsx packages/config-web/src/bin.ts",
    "arch:graph": "tsx docs/scripts/build-arch-graph.ts",
    "arch:serve": "tsx docs/scripts/serve-arch-graph.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
