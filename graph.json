{
  "project": {
    "name": "OpenKrakey",
    "description": "Minimalist microkernel autonomous-agent framework (TypeScript/Node). Per-Agent: clock + event-system + orchestrator(+context-buffer) + loader, wrapped by agent_instance. Global: boot + cli.",
    "created_at": "2026-06-07T00:00:00Z",
    "updated_at": "2026-06-07T00:00:00Z"
  },
  "zones": {
    "core": {
      "description": "The whole framework — per-Agent runtime modules + their L1 contracts + shared modules + the two global modules (boot, cli) + the LLM communication gateway.",
      "nodes": ["clock", "event-system", "orchestrator", "loader", "agent_instance", "boot", "cli", "llm-gateway"],
      "overview": "overviews/zones/core.md"
    }
  },
  "nodes": {
    "clock": {
      "zone": "core",
      "path": "packages/clock",
      "description": "Per-Agent dumb timer: countdown + activate; rhythm controllable.",
      "depends_on_contracts": [],
      "implements_contracts": ["clock"],
      "status": "pending",
      "overview": "overviews/nodes/clock.md"
    },
    "event-system": {
      "zone": "core",
      "path": "packages/event-system",
      "description": "Per-Agent independent central bus: eventbus + actionbus; clock/loader/orchestrator/plugins all connect.",
      "depends_on_contracts": [],
      "implements_contracts": ["event-system"],
      "status": "pending",
      "overview": "overviews/nodes/event-system.md"
    },
    "orchestrator": {
      "zone": "core",
      "path": "packages/orchestrator",
      "description": "Per-Agent conductor; CONTAINS the context-buffer. Event-driven beat: gather→compose→llm.request; dispatch tool calls from llm.return.",
      "depends_on_contracts": ["event-system", "clock", "context", "llm"],
      "implements_contracts": ["orchestrator"],
      "status": "pending",
      "overview": "overviews/nodes/orchestrator.md"
    },
    "loader": {
      "zone": "core",
      "path": "packages/loader",
      "description": "Per-Agent plugin lifecycle: copy independents, load private(override)+public, set dataDir, inject llm library, register (setup) into event-system, teardown.",
      "depends_on_contracts": ["plugin", "event-system", "context", "orchestrator", "llm"],
      "implements_contracts": ["loader"],
      "status": "pending",
      "overview": "overviews/nodes/loader.md"
    },
    "agent_instance": {
      "zone": "core",
      "path": "packages/agent_instance",
      "description": "Wraps ONE Agent: holds+wires clock+event-system+orchestrator+loader; receives the global llm library; start()->loader loads->orchestrator conducts; stop().",
      "depends_on_contracts": ["clock", "event-system", "orchestrator", "loader", "agent", "llm"],
      "implements_contracts": ["agent"],
      "status": "pending",
      "overview": "overviews/nodes/agent_instance.md"
    },
    "boot": {
      "zone": "core",
      "path": "packages/boot",
      "description": "Global startup ONLY: read each agent's config + config/llm.json, build the global llm library, build + launch each agent_instance. Composition root.",
      "depends_on_contracts": ["agent", "llm"],
      "implements_contracts": [],
      "status": "pending",
      "overview": "overviews/nodes/boot.md"
    },
    "cli": {
      "zone": "core",
      "path": "packages/cli",
      "description": "Global standalone interactive (@inquirer/prompts) config tool: arrow-key pages to edit agent configs, the Default Setting, and the LLM communicator catalogue; Krakey logo; krakey/krakey agent/krakey default deep-links.",
      "depends_on_contracts": ["agent"],
      "implements_contracts": [],
      "status": "pending",
      "overview": "overviews/nodes/cli.md"
    },
    "llm-gateway": {
      "zone": "core",
      "path": "packages/llm-gateway",
      "description": "Global LLM communication module: builds a key-less CommunicatorLibrary from config/llm.json (provider adapters: anthropic, openai-compatible; native fetch). Holds keys; does request+parse. Industry-standard infra, solidified into core.",
      "depends_on_contracts": ["llm"],
      "implements_contracts": ["llm"],
      "status": "pending",
      "overview": "overviews/nodes/llm-gateway.md"
    }
  },
